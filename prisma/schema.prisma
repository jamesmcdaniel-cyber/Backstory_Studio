generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String    @unique
  plan             Plan      @default(TRIAL)
  trialStartDate   DateTime  @default(now()) @db.Timestamptz(6)
  trialEndDate     DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  users          User[]
  agents         AgentTask[]
  executions     AgentExecution[]
  templates      AgentTemplate[]
  integrations   Integration[]
  mcpAgents      MCPAgent[]
  notifications  Notification[]
  mcpConnections McpConnection[]

  @@map("organizations")
}

model User {
  id             String    @id @default(cuid())
  supabaseId     String    @unique @db.Uuid
  email          String?
  name           String?
  imageUrl       String?
  role           UserRole  @default(USER)
  organizationId String?   @db.Uuid
  isActive       Boolean   @default(true)
  lastSeenAt     DateTime? @db.Timestamptz(6)
  timezone       String    @default("UTC")
  metadata       Json?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   AgentExecution[]
  templates    AgentTemplate[]
  integrations Integration[]
  mcpAgents    MCPAgent[]

  @@index([organizationId])
  @@map("users")
}

model AgentTask {
  id             String    @id @default(cuid())
  type           String    @default("agent")
  priority       String    @default("MEDIUM")
  agentType      String    @default("CUSTOM")
  description    String    @db.Text
  objective      String    @db.Text
  context        Json      @default("{}")
  schedule       Json      @default("{}")
  status         String    @default("ACTIVE")
  folder         String?
  visibility     String    @default("shared")
  organizationId String    @db.Uuid
  metadata       Json?
  lastExecutedAt DateTime?
  executionCount Int       @default(0)
  lastResult     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   AgentExecution[]

  @@index([organizationId, status])
  @@map("agent_tasks")
}

model AgentExecution {
  id              String    @id @default(cuid())
  agentType       String
  agentTemplateId String?
  agentTaskId     String?
  status          String    @default("pending")
  input           Json
  output          Json?
  error           String?
  executionTime   Int?      @default(0)
  trigger         Json
  metadata        Json?
  model           String?
  transcript      Json?
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  userId          String
  organizationId  String    @db.Uuid
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentTemplate AgentTemplate?     @relation(fields: [agentTemplateId], references: [id], onDelete: SetNull)
  agentTask     AgentTask?         @relation(fields: [agentTaskId], references: [id], onDelete: SetNull)
  workflowSteps WorkflowStep[]
  events        WorkflowEvent[]
  messages      ExecutionMessage[]

  @@index([organizationId, startedAt])
  @@index([agentTaskId])
  @@map("agent_executions")
}

model ExecutionMessage {
  id          String   @id @default(cuid())
  executionId String
  role        String
  content     String   @db.Text
  createdAt   DateTime @default(now())

  execution AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@map("execution_messages")
}

model Notification {
  id             String    @id @default(cuid())
  organizationId String    @db.Uuid
  userId         String?
  type           String
  level          String    @default("info")
  title          String
  body           String?   @db.Text
  agentTaskId    String?
  executionId    String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, userId, readAt])
  @@map("notifications")
}

model PushSubscription {
  id             String   @id @default(cuid())
  userId         String
  organizationId String   @db.Uuid
  endpoint       String   @unique @db.Text
  p256dh         String   @db.Text
  auth           String   @db.Text
  createdAt      DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model WorkflowStep {
  id          String    @id @default(cuid())
  executionId String
  node        String
  status      String
  input       Json      @default("{}")
  output      Json?
  error       Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  execution AgentExecution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  events    WorkflowEvent[]

  @@index([executionId, createdAt])
  @@map("workflow_steps")
}

model WorkflowEvent {
  id          String   @id @default(cuid())
  executionId String
  stepId      String?
  kind        String
  payload     Json?
  ts          DateTime @default(now())

  execution AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      WorkflowStep?  @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([executionId, ts])
  @@map("workflow_events")
}

model AgentTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  type           String
  configuration  Json?
  isActive       Boolean  @default(true)
  schedule       String?
  priority       String   @default("MEDIUM")
  metadata       Json?
  userId         String
  organizationId String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   AgentExecution[]

  @@index([organizationId, isActive])
  @@map("agent_templates")
}

model Integration {
  id             String    @id @default(cuid())
  userId         String
  organizationId String    @db.Uuid
  provider       String
  expiresAt      DateTime? @db.Timestamptz(6)
  scopes         String[]  @default([])
  status         String    @default("connected")
  failCount      Int       @default(0)
  lastError      String?   @db.Text
  metadata       Json      @default("{}")
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([organizationId, provider])
  @@map("integrations")
}

model MCPAgent {
  id             String  @id @default(cuid())
  userId         String
  organizationId String  @db.Uuid
  name           String
  agentType      String
  description    String?
  mcpServerUrl   String
  isActive       Boolean      @default(false)
  configuration  Json         @default("{}")
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, agentType])
  @@map("mcp_agents")
}

model McpConnection {
  id             String   @id @default(cuid())
  organizationId String   @db.Uuid
  name           String
  description    String?
  serverUrl      String
  authType       String   @default("none")   // 'none' | 'api_key' | 'oauth2'
  authConfig     Json     @default("{}")     // encrypted secret blob + non-secret fields
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@map("mcp_connections")
}

enum Plan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  ADMIN
  USER
}
