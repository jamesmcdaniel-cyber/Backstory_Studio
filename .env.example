# Web and authentication
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Data and worker
# Serverless (Vercel): DATABASE_URL = Supabase Transaction pooler (port 6543) with
# ?pgbouncer=true&connection_limit=1. DIRECT_URL = Session pooler (5432) for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DB?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB
REDIS_URL=redis://localhost:6379
AGENT_WORKER_CONCURRENCY=3
WORKER_PORT=3002

# Agent runtime — model provider
# OpenAI is the default provider. Set OPENAI_API_KEY and agents, the activity
# headlines, run Q&A, and the "describe an agent" builder all run on OpenAI.
OPENAI_API_KEY=
# Optional model overrides (OpenAI model ids by default).
AGENT_MODEL=gpt-4o
SUMMARY_MODEL=gpt-4o-mini
# Optional — only needed if you pick a Claude (claude-*) model for an agent.
# Leave blank to run entirely on OpenAI.
ANTHROPIC_API_KEY=
KLAVIS_API_KEY=
AGENT_MAX_TURNS=16
# Optional: cap total (input+output) tokens per org per UTC month. 0/unset = unlimited.
AGENT_MONTHLY_TOKEN_LIMIT=0

# Pipedream embedded integrations
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_PROJECT_ENVIRONMENT=development

# Web push (browser notifications) — optional; in-app notifications work without it.
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
