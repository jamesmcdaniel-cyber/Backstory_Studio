# Web and authentication
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Data and worker
# Serverless (Vercel): DATABASE_URL = Supabase Transaction pooler (port 6543) with
# ?pgbouncer=true&connection_limit=1. DIRECT_URL = Session pooler (5432) for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DB?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB
REDIS_URL=redis://localhost:6379
AGENT_WORKER_CONCURRENCY=3
WORKER_PORT=3002

# Agent runtime — model provider
# Anthropic (Claude) is the provider. Set ANTHROPIC_API_KEY — agents, the
# activity headlines, run Q&A, the copilot, and the "describe an agent" builder
# all run on Claude. Boot fails in production without a provider key.
ANTHROPIC_API_KEY=
# Optional model overrides — Claude model ids (claude-*). Defaults are set in
# src/lib/llm/model-runner.ts; leave unset to use them.
AGENT_MODEL=
SUMMARY_MODEL=
# Alternative provider: Qwen via DashScope's Anthropic-compatible endpoint.
# Set BOTH to use it instead of Claude (leave ANTHROPIC_API_KEY blank).
QWEN_API_KEY=
QWEN_BASE_URL=
AGENT_MAX_TURNS=16
# Optional: cap total (input+output) tokens per org per UTC month. 0/unset = unlimited.
AGENT_MONTHLY_TOKEN_LIMIT=0

# People.ai Sales AI (identity + entitlement gate + read tools)
# OAuth app credentials identifying Backstory Studio as an MCP client of
# mcp.people.ai — per-user connections happen through the browser flow.
PEOPLE_AI_OAUTH_CLIENT_ID=
PEOPLE_AI_OAUTH_CLIENT_SECRET=
# Optional: scope assigned by People.ai; MCP base URL override for testing.
PEOPLE_AI_OAUTH_SCOPE=
PEOPLE_AI_MCP_BASE_URL=
# Org-level Sales AI service credential (PAI-Client-Id / PAI-Client-Secret,
# self-served in the People.ai API settings). Setting BOTH turns on "native
# Sales AI mode": every workspace is assumed entitled and Sales AI works out of
# the box with no per-user OAuth (per-user connections stay an optional upgrade
# for rep-scoped reads/actions). Also used for non-interactive signal runs.
PEOPLE_AI_SERVICE_CLIENT_ID=
PEOPLE_AI_SERVICE_CLIENT_SECRET=
# SalesAI signal webhooks: shared secret for verifying inbound webhook
# signatures (from POST /v1/salesai/webhooks registration), and optional API
# base override. The receiver is disabled until the secret is set.
PEOPLE_AI_WEBHOOK_SECRET=
PEOPLE_AI_SALESAI_BASE_URL=
# Entitlement gate: defaults on in production, off in development.
# Force with 'on'/'off'. Keep 'off' in prod until the OAuth flow is verified.
ENTITLEMENT_GATE=
# Password signup: set 'false' to force SSO/invite-only (production).
AUTH_ALLOW_PASSWORD=

# Graph-RAG brain (correlates Sales AI signals + integration/MCP data + prior
# runs to give agents and the assistant richer context). All optional and
# gated: with none set, RAG is a clean no-op and nothing changes.
# Embeddings — Voyage AI (dashboard.voyageai.com → API Keys, pa-...).
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=
# Graph store — Neo4j (AuraDB or self-hosted). All three required for a durable
# graph; without them the store falls back to per-process in-memory.
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Nango connected accounts (Connect UI + backend SDK). Nango is the single
# integration provider (OAuth storage + tool proxy) — it replaced Klavis.
# Setup + the exact dashboard integration ids to enable: docs/nango-setup.md
# Environment secret key from the Nango dashboard (Environment settings). Also
# verifies the /api/nango/webhook signature — no separate webhook secret.
NANGO_SECRET_KEY=
# Optional — self-hosted or regional Nango API host. Leave blank for Nango Cloud.
NANGO_HOST=
# Optional — self-hosted Connect UI base URL. Leave blank for https://connect.nango.dev.
NEXT_PUBLIC_NANGO_CONNECT_URL=
# Optional — per-request Nango proxy ceiling (ms) for delivery/tool calls. Default 20000.
NANGO_PROXY_TIMEOUT_MS=

# Secrets at rest — encrypts MCP connection and integration API keys
# (any non-empty string works; without it secrets fall back to plain base64).
ENCRYPTION_KEY=

# Granola meeting notes — optional global fallback API key (grn_...).
# Each workspace can save its own key on the integrations page, which takes
# precedence over this value.
GRANOLA_API_KEY=

# Web push (browser notifications) — optional; in-app notifications work without it.
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
