{
  "name": "backstory-studio",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "worker:dev": "tsx watch src/lib/workers/runtime.ts",
    "worker:start": "tsx src/lib/workers/runtime.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "tsx --test src/**/__tests__/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@nangohq/frontend": "^0.70.9",
    "@nangohq/node": "^0.70.9",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@types/web-push": "^3.6.4",
    "bullmq": "^5.58.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.5.0",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.513.0",
    "next": "^15.5.19",
    "openai": "^5.20.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.0",
    "tsx": "^4.20.5",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.6",
    "prisma": "^6.14.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
